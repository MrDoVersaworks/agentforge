# Database
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth
JWT_ACCESS_SECRET=your_jwt_access_secret_32_bytes_hex
JWT_REFRESH_SECRET=your_jwt_refresh_secret_32_bytes_hex

# Encryption (64 hex chars = 32 bytes for AES-256-GCM)
AES_ENCRYPTION_KEY=your_aes_encryption_key_64_hex_chars

# Server
PORT=5003
NODE_ENV=development
CORS_ORIGIN=http://localhost:3003
GEMINI_API_KEY=your_google_gemini_api_key
